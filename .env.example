# Hermes Chat UI - Environment Variables
# Copy this file to .env and fill in the values

VITE_HERMES_API_URL=http://localhost:8000
VITE_HERMES_WS_URL=ws://localhost:8000/ws

# Push Notifications (VAPID)
# Generate with: python -c "from cryptography.hazmat.primitives.asymmetric import ec; from cryptography.hazmat.primitives import serialization; key = ec.generate_private_key(ec.SECP256R1()); print('VAPID_PRIVATE_KEY=' + key.private_bytes(serialization.Encoding.PEM, serialization.PrivateFormat.PKCS8, serialization.NoEncryption()).decode()); print('VAPID_PUBLIC_KEY=' + key.public_key().public_bytes(serialization.Encoding.PEM, serialization.PublicFormat.SubjectPublicKeyInfo).decode())"
# Or let the entrypoint generate them automatically
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# VAPID keys file path (auto-generated if not set)
VAPID_KEYS_FILE=/app/vapid_keys.json
