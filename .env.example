# ──────────────────────────────────────────────
# Hermes Chat UI — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# === Docker Ports ===
BACKEND_PORT=8642          # Hermes Agent native API (internal)
PROXY_PORT=8643            # Chat UI proxy (serves web UI + augmented API)

# === Hermes Core ===
HERMES_API_KEY=changeme    # REQUIRED — API key shared between UI and agent (set your own)

# === API Server (Hermes Agent built-in) ===
API_SERVER_ENABLED=true
API_SERVER_KEY=changeme    # Same as HERMES_API_KEY
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8642
API_SERVER_CORS_ORIGINS=*
API_SERVER_MODEL_NAME=     # Default model name (e.g., hermes-3-llama-3.1-8b)

# === Home Assistant Integration (Optional) ===
HA_URL=                    # e.g., http://homeassistant.local:8123
HA_TOKEN=                  # Long-lived access token

# === GitHub Integration (Optional) ===
GITHUB_TOKEN=              # Personal access token for GitHub tools
